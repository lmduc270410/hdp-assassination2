#!/usr/bin/env python3
"""
free_promptsafe_adaptive.py

Competitive-programming subproblem generator with:
- URL / raw text / .txt / .md / .docx input
- Gemini API backend via google-genai
- JSON + LaTeX export, optional PDF
- Streamlit local web UI with a project queue

Design goals:
- Model writes plain contest-style notation in JSON (N, K, <=, sqrt(N), log(N), A_i, O(n log n))
- JSON stays parseable and plain-text friendly
- Python converts math-like notation into LaTeX only during rendering
- LaTeX remains stable even when the model uses adaptive variables like N, K, M, Q

Install:
  pip install requests beautifulsoup4 python-docx streamlit google-genai
"""

from __future__ import annotations

import argparse
import dataclasses
